{
  "servers": [
    {
      "name": "playwright",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless"]
    },
    {
      "name": "playwright-test",
      "command": "npx",
      "args": ["playwright", "run-test-mcp-server", "-c", "playwright.config.ts"]
    },
    {
      "name": "playwright-qa",
      "command": "node",
      "args": ["mcp-server/dist/index-mcp.js"]
    }
  ]
}
