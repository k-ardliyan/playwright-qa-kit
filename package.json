{
  "name": "playwright-qa-kit",
  "version": "0.1.0-alpha.2",
  "private": true,
  "description": "Reusable Playwright E2E acceleration framework with interactive runner, page objects, custom reporting, and AI-assisted workflow support",
  "keywords": [
    "playwright",
    "e2e",
    "qa",
    "automation",
    "typescript",
    "page-object-model",
    "test-accelerator"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate": "tsx validate-generated-tests.ts",
    "validate:requirement": "tsx validate-requirement.ts",
    "setup:check": "tsx setup-check.ts",
    "health:check": "tsx scripts/health-check-cli.ts",
    "install:mcp-server": "npm ci --prefix mcp-server",
    "prepare": "husky",
    "pretest": "npm run setup:check && npm run lint && npm run typecheck",
    "test": "npx playwright test --grep-invert @demo",
    "test:fast": "npx playwright test --grep-invert @demo",
    "test:demo": "npx playwright test --project=demo --workers=1",
    "test:ci": "npx playwright test --grep-invert @demo",
    "test:property": "tsx scripts/run-property-tests.ts",
    "test:quality": "npm run install:mcp-server && npm run format:check && npm run lint && npm run typecheck && npx tsc -p mcp-server/tsconfig.json --noEmit && npm run validate && npm run validate:requirement -- requirements/example-login-extension.md && npm run test:property && npm run mcp:build && npm run health:check",
    "test:custom": "tsx src/shared/utils/cli-runner.ts",
    "test:headed": "npx playwright test --headed --grep-invert @demo",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:erpku-example": "npx playwright test -c example/erpku/playwright.config.ts",
    "mcp:build": "npm run install:mcp-server && cd mcp-server && npm run build",
    "mcp:dev": "cd mcp-server && npx tsx src/index-mcp.ts",
    "snapshot:page": "tsx scripts/snapshot-page-cli.ts",
    "discover:pages": "tsx scripts/discover-pages-cli.ts"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.74.3",
    "@eslint/js": "^10.0.1",
    "@playwright/mcp": "^0.0.76",
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.17.0",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.5.0",
    "eslint-plugin-playwright": "^2.10.4",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.8.4",
    "prompts": "^2.4.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
