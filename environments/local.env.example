# Salin → environments/local.env (jangan commit file berisi password nyata)
# Panduan: docs/GUIDE.md · Workshop: docs/WORKSHOP.md

# ── URL Aplikasi ─────────────────────────────────────────────────
BASE_URL=http://localhost:3000/

# ── Nama Environment (logging) ───────────────────────────────────
ENV_NAME=local

# ── Kredensial QA ────────────────────────────────────────────────
TEST_USER_EMAIL=test@example.com
TEST_USER_USERNAME=testuser
TEST_USER_PASSWORD=your_password_here

# ── Browser (opsional) ───────────────────────────────────────────
HEADLESS=true
SLOW_MO=0

# ── Playwright profile ───────────────────────────────────────────
# Path A (default — template core, spec di src/tests/):
PLAYWRIGHT_CONFIG=playwright.config.ts

# Path B (ERPKU adapter — spec di example/erpku/tests/):
# PLAYWRIGHT_CONFIG=example/erpku/playwright.config.ts
# Salin AUTH_* dan TEST_USER_PHONE dari example/erpku/environments/erpku.env.example ke file ini.
# Setelah ubah: restart MCP servers di IDE.
