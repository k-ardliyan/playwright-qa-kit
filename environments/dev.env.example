# Salin → environments/dev.env · jalankan dengan APP_ENV=dev
# Panduan: docs/GUIDE.md

# ── URL Aplikasi ─────────────────────────────────────────────────
BASE_URL=https://dev.your-app.example.com/

# ── Nama Environment (logging) ───────────────────────────────────
ENV_NAME=dev

# ── Kredensial QA ────────────────────────────────────────────────
TEST_USER_EMAIL=test@example.com
TEST_USER_USERNAME=testuser
TEST_USER_PHONE=081234567890
TEST_USER_PASSWORD=your_password_here

# ── Browser (opsional) ───────────────────────────────────────────
HEADLESS=true
SLOW_MO=0

# ── Playwright profile ───────────────────────────────────────────
# Path A (default):
PLAYWRIGHT_CONFIG=playwright.config.ts

# Path B (ERPKU):
# PLAYWRIGHT_CONFIG=example/erpku/playwright.config.ts
# Salin AUTH_* dari example/erpku/environments/erpku.env.example ke file ini.
