# Dependencies
node_modules/

# Per-environment files (contain real credentials — never commit)
# Create environments/{local|dev|staging|production}.env with your credentials.
# Template examples (*.env.example) are tracked for reference.
environments/*.env
!environments/*.env.example

# Playwright artifacts
test-results/
playwright-report/
blob-report/

# Reports (generated)
reports/
!reports/.gitkeep

# Selector catalog (regenerable from snapshot_page / discover_pages MCP tools)
selector-catalog/
!selector-catalog/.gitkeep
!selector-catalog/.meta.json

# Logger output
logs/

# Auth state cache (login cookies/localStorage)
.auth/

# Property test transient artifacts
src/tests/__property_validator__/

# TypeScript
*.tsbuildinfo
mcp-server/dist/

# Local agent tooling (not part of release)
.agents/
.claude/

# OS
.DS_Store
Thumbs.db

# IDEs
.idea/
*.swp
*.swo
.vscode/settings.json

# Local debug / temp artifacts
debug-validator.ts
*.diff
