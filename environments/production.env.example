# ── URL Aplikasi ─────────────────────────────────────────────────
# URL lengkap aplikasi yang akan ditest
BASE_URL=https://qa.your-app.example.com/

# ── Nama Environment ─────────────────────────────────────────────
# Digunakan untuk logging dan conditional logic (dev | stg | prod)
ENV_NAME=qa

# Email akun QA test
TEST_USER_EMAIL=test@example.com
# Username akun QA test
TEST_USER_USERNAME=testuser
# Nomor Telepon akun QA test
TEST_USER_PHONE=081234567890
# Password akun QA test
TEST_USER_PASSWORD=your_password_here

# ── Browser Behavior (opsional) ──────────────────────────────────
HEADLESS=true
SLOW_MO=0
