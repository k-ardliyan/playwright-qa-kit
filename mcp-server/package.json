{
  "name": "playwright-qa-mcp-server",
  "version": "2.0.0",
  "description": "MCP server exposing QA-specific tools for the Playwright AI Agent Framework via stdio transport",
  "main": "dist/index-mcp.js",
  "bin": {
    "playwright-qa-mcp": "./dist/index-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index-mcp.js",
    "start:http": "node dist/index.js",
    "dev": "tsx src/index-mcp.ts",
    "dev:http": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
